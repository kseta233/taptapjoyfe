# WebSocket endpoint used by the frontend at build time.
# PWA deploy: set to your public WSS endpoint.
# Android emulator local backend example: ws://10.0.2.2:3001
# iOS simulator local backend example: ws://127.0.0.1:3001
VITE_WS_URL=ws://localhost:3001

# Optional explicit HTTPS API endpoint.
# If omitted, config.ts derives this from VITE_WS_URL (ws->http / wss->https).
# Example: https://api.example.com
VITE_HTTPS_URL=

# Backward-compatible alias still supported by src/config.ts.
VITE_API_URL=
